# Master wallet seed (mnemonic or hex) — required for --fund and --run
MASTER_SEED=

# Number of wallets to create (default: 5)
WALLET_COUNT=5

# VARA to transfer to each wallet (default: 0.5)
VARA_PER_WALLET=0.5

# Vara RPC endpoint (default: wss://rpc.vara.network)
RPC=wss://rpc.vara.network

# Max parallel operations (default: 3)
CONCURRENCY=3

# DEX program ID (default: current mainnet program)
PROGRAM_ID=0x7fa1988c57ba1134e2461c5fb36bc13d66c1dfbf47d36c5e9960b9ca2dc0e4c4
